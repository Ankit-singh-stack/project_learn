# Backend environment variables
PORT=5000
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/<database_name>
# Use the actual Razorpay API Key ID, for example:
# RAZORPAY_KEY_ID=rzp_test_1234567890abcdef
# Do NOT paste the Razorpay.me merchant link here.
RAZORPAY_KEY_ID=<your_razorpay_key_id>
RAZORPAY_KEY_SECRET=<your_razorpay_key_secret>
JWT_SECRET=<your_jwt_secret>
